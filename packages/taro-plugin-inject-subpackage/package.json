{
  "name": "taro-plugin-inject-subpackage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm,cjs --dts",
    "dev": "tsdown src/index.ts --format esm,cjs --dts --watch"
  },
  "devDependencies": {
    "tsdown": "^0.12.9",
    "typescript": "^5.1.0"
  }
}
